# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo (los archivos que ya subimos)
COPY . .

# 2. SCRIPT DE CURACIÓN: Inyectamos packageManager y preparamos el entorno
RUN node -e "const fs=require('fs'); \
    const fix = (p) => { \
    if (!fs.existsSync(p)) return null; \
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8')); \
    const clean = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { if (d.startsWith('@plane/') || deps[d].includes('catalog:') || deps[d].includes('workspace:')) delete deps[d]; } \
    }; \
    clean(pkg.dependencies); clean(pkg.devDependencies); \
    return pkg; \
    }; \
    const rootPkg = fix('package.json'); \
    if (rootPkg) { \
    rootPkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync('package.json', JSON.stringify(rootPkg, null, 2)); \
    } \
    const webPkg = fix('apps/web/package.json'); \
    if (webPkg) fs.writeFileSync('apps/web/package.json', JSON.stringify(webPkg, null, 2)); \
    fs.writeFileSync('pnpm-workspace.yaml', 'packages:\n  - \"apps/web\"\n  - \"packages/*\"');"

# 3. Instalación de dependencias
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 4. Build forzada: Si Turbo falla por las rutas, intentamos entrar directo a la carpeta
RUN pnpm turbo run build --filter=web || (cd apps/web && pnpm run build)

# --- NGINX: Servir la aplicación ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html

# Copiamos desde la ruta de salida de Plane (ajusta si en tu PC es 'dist')
COPY --from=builder /app/apps/web/build/client/. ./

RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]