# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos todo
COPY . .

# 2. SCRIPT DE CONVERSIÓN: Pasamos dependencias de workspace a rutas relativas
RUN node -e "const fs=require('fs'); const path=require('path'); \
    const fixPkg = (p) => { \
    if (!fs.existsSync(p)) return; \
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8')); \
    const fix = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { \
    if (deps[d].includes('catalog:')) deps[d] = '*'; \
    if (deps[d].includes('workspace:')) { \
    const name = d.replace('@plane/', ''); \
    deps[d] = 'link:../../packages/' + name; \
    } \
    } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); \
    fs.writeFileSync(p, JSON.stringify(pkg, null, 2)); \
    }; \
    fixPkg('package.json'); \
    fixPkg('apps/web/package.json');"

# 3. Instalación con los links creados
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 4. Build de Vite/React-Router
WORKDIR /app/apps/web
# Añadimos una bandera para ver el error real si falla
RUN pnpm run build || (ls -R /app/packages && exit 1)

# --- NGINX ---
FROM nginx:1.27-alpine AS production
COPY --from=builder /app/apps/web/build/client /usr/share/nginx/html
RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf
EXPOSE 3000