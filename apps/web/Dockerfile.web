# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base

RUN npm install -g pnpm@10.32.1 turbo@2.9.4

# *****************************************************************************
# STAGE 1: Build
# *****************************************************************************
FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Forzamos que se ignore el .dockerignore para las carpetas críticas
COPY . .

# BYPASS TOTAL: Eliminamos la dependencia de "catalogs" convirtiendo todo a versiones dinámicas
RUN node -e "const fs=require('fs'); \
    const pkgPath = 'apps/web/package.json'; \
    const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf-8')); \
    const fix = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { if (deps[d].includes('catalog:')) deps[d] = '*'; } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); \
    fs.writeFileSync(pkgPath, JSON.stringify(pkg, null, 2)); \
    const rootPkg = JSON.parse(fs.readFileSync('package.json', 'utf-8')); \
    rootPkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync('package.json', JSON.stringify(rootPkg, null, 2)); \
    fs.writeFileSync('pnpm-workspace.yaml', 'packages:\n  - \"apps/*\"\n  - \"packages/*\"');"

# Instalamos (Ahora ya no hay catalogs que lo detengan)
RUN pnpm install --no-frozen-lockfile

# Variables de entorno
ARG VITE_API_BASE_URL=""
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ARG VITE_ADMIN_BASE_URL=""
ENV VITE_ADMIN_BASE_URL=$VITE_ADMIN_BASE_URL

# Build
RUN pnpm turbo run build --filter=web

# *****************************************************************************
# STAGE 2: Nginx
# *****************************************************************************
FROM nginx:1.27-alpine AS production
RUN cat <<EOF > /etc/nginx/nginx.conf
worker_processes auto;
events { worker_connections 1024; }
http {
    include mime.types;
    server {
        listen 3000; root /usr/share/nginx/html; index index.html;
        location / { try_files \$uri \$uri/ /index.html; }
    }
}
EOF
COPY --from=builder /app/apps/web/build/client /usr/share/nginx/html
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]