# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Forzamos la creación de la estructura de carpetas
RUN mkdir -p apps/web packages

# 2. Copiamos los archivos de configuración de la raíz
COPY package.json pnpm-workspace.yaml* pnpm-lock.yaml* ./

# 3. Copiamos específicamente las carpetas que Railway está ignorando
COPY apps/ ./apps/
COPY packages/ ./packages/

# 4. Limpieza de catálogos (Bypass de pnpm v10)
RUN node -e "const fs=require('fs'); const path=require('path'); \
    const walk = (dir) => { \
    if (!fs.existsSync(dir)) return; \
    fs.readdirSync(dir).forEach(file => { \
    let name = path.join(dir, file); \
    if (fs.statSync(name).isDirectory()) { \
    if (file !== 'node_modules') walk(name); \
    } else if (file === 'package.json') { \
    let pkg = JSON.parse(fs.readFileSync(name, 'utf-8')); \
    let changed = false; \
    const fix = (deps) => { \
    for (let d in deps) { if (deps[d] && deps[d].includes('catalog:')) { deps[d] = '*'; changed = true; } } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); \
    if (changed || name === 'package.json') { \
    fs.writeFileSync(name, JSON.stringify(pkg, null, 2)); \
    console.log('Fixed: ' + name); \
    } \
    } \
    }); \
    }; \
    walk('.');"

# 5. Instalación (Con banderas de emergencia)
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 6. Build
RUN pnpm turbo run build --filter=web

# *****************************************************************************
# STAGE 2: Nginx
# *****************************************************************************
FROM nginx:1.27-alpine AS production
RUN cat <<EOF > /etc/nginx/nginx.conf
worker_processes auto;
events { worker_connections 1024; }
http {
    include mime.types;
    server {
        listen 3000; root /usr/share/nginx/html; index index.html;
        location / { try_files \$uri \$uri/ /index.html; }
    }
}
EOF
COPY --from=builder /app/apps/web/build/client /usr/share/nginx/html
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]