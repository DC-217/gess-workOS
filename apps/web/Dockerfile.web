# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo completo
COPY . .

# 2. SCRIPT DE LIMPIEZA RECURSIVA
RUN node -e "const fs = require('fs'); const path = require('path'); \
    const walk = (dir) => { \
    fs.readdirSync(dir).forEach(file => { \
    let name = path.join(dir, file); \
    if (fs.statSync(name).isDirectory()) { \
    if (file !== 'node_modules' && file !== '.git') walk(name); \
    } else if (file === 'package.json') { \
    const pkg = JSON.parse(fs.readFileSync(name, 'utf-8')); \
    const fix = (obj) => { \
    if (!obj) return; \
    for (let k in obj) { \
    if (typeof obj[k] === 'string' && obj[k].includes('catalog:')) obj[k] = '*'; \
    if (typeof obj[k] === 'string' && obj[k].includes('workspace:')) obj[k] = 'workspace:*'; \
    } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); fix(pkg.peerDependencies); \
    if (pkg.overrides) fix(pkg.overrides); \
    if (pkg.pnpm && pkg.pnpm.overrides) fix(pkg.pnpm.overrides); \
    if (name === 'package.json') pkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync(name, JSON.stringify(pkg, null, 2)); \
    } \
    }); \
    }; \
    walk('.');"

# 3. Instalación
RUN pnpm install --no-frozen-lockfile

# 4. Build de la web (Órbita)
RUN pnpm turbo run build --filter=web

# ... (todo lo anterior del builder igual)

# --- NGINX: Producción ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html
COPY --from=builder /app/apps/web/build/client/. ./

RUN printf "server { \n\
    listen 3000; \n\
    proxy_buffer_size 128k; \n\
    proxy_buffers 4 256k; \n\
    proxy_busy_buffers_size 256k; \n\
    location ^~ /api/ { \n\
    proxy_pass https://gess-workos-api-production.up.railway.app/api/; \n\
    proxy_set_header Host gess-workos-api-production.up.railway.app; \n\
    proxy_set_header X-Real-IP \$remote_addr; \n\
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for; \n\
    proxy_set_header X-Forwarded-Proto https; \n\
    proxy_set_header X-Forwarded-Host \$host; \n\
    proxy_ssl_server_name on; \n\
    } \n\
    location / { \n\
    root /usr/share/nginx/html; \n\
    try_files \$uri \$uri/ /index.html; \n\
    } \n\
    }\n" > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]