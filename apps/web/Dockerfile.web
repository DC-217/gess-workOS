# --- NGINX: Producción ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html

# Copiamos los archivos compilados
COPY --from=builder /app/apps/web/build/client/. ./

# Configuramos Nginx con prioridad absoluta y limpieza de headers
RUN printf "server { \n\
    listen 3000; \n\
    # 1. Captura cualquier llamada que empiece con /api/ con prioridad \n\
    location ^~ /api/ { \n\
    proxy_pass https://gess-workos-api-production.up.railway.app/api/; \n\
    proxy_set_header Host gess-workos-api-production.up.railway.app; \n\
    proxy_set_header X-Real-IP \$remote_addr; \n\
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for; \n\
    proxy_set_header X-Forwarded-Proto \$scheme; \n\
    proxy_ssl_server_name on; \n\
    proxy_ssl_session_reuse off; \n\
    } \n\
    # 2. Manejo de rutas para Single Page Application \n\
    location / { \n\
    root /usr/share/nginx/html; \n\
    try_files \$uri \$uri/ /index.html; \n\
    } \n\
    }\n" > /etc/nginx/conf.d/default.conf

# Importante: Puerto 3000 coincidente
EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]