# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo
COPY . .

# 2. CIRUGÍA DE PACKAGE.JSON: Quitamos lo que bloquea a pnpm
RUN node -e "const fs=require('fs'); \
    const pkg = JSON.parse(fs.readFileSync('package.json', 'utf-8')); \
    const clean = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { \
    if (deps[d].includes('workspace:') || deps[d].includes('catalog:')) delete deps[d]; \
    } \
    }; \
    clean(pkg.dependencies); clean(pkg.devDependencies); \
    fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2)); \
    fs.writeFileSync('pnpm-workspace.yaml', 'packages:\n  - \"apps/web\"\n  - \"packages/*\"');"

# 3. INSTALACIÓN REAL: Ahora sí, bajamos los paquetes
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 4. COMPILACIÓN: Entramos a la app y construimos
WORKDIR /app/apps/web
RUN pnpm run build

# --- NGINX: Servir los archivos estáticos ---
FROM nginx:1.27-alpine AS production
# Nota: Plane/Vite suele generar la build en 'dist' o 'build/client'
# Si esta ruta falla, revisa el nombre de la carpeta de salida en tu PC
COPY --from=builder /app/apps/web/build/client /usr/share/nginx/html

RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]