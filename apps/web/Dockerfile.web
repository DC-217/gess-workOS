# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo (los 1226 archivos que ya tenemos limpios)
COPY . .

# 2. SCRIPT QUIRÚRGICO: Quitamos @plane y arreglamos catálogos sin romper la sintaxis
RUN node -e "const fs=require('fs'); \
    const fix = (p) => { \
    if (!fs.existsSync(p)) return; \
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8')); \
    const clean = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { \
    if (d.startsWith('@plane/')) { delete deps[d]; } \
    else if (deps[d].includes('catalog:') || deps[d].includes('workspace:')) { deps[d] = '*'; } \
    } \
    }; \
    clean(pkg.dependencies); clean(pkg.devDependencies); \
    fs.writeFileSync(p, JSON.stringify(pkg, null, 2)); \
    }; \
    fix('package.json'); fix('apps/web/package.json');"

# 3. Instalación de dependencias
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 4. SOLUCIÓN AL TSCONFIG: Movemos las configs a la raíz para que react-router las vea
RUN cp apps/web/tsconfig.json ./tsconfig.json && \
    cp apps/web/react-router.config.ts ./react-router.config.ts && \
    cp apps/web/vite.config.ts ./vite.config.ts || true

# 5. Build: Usamos Turbo para orquestar la compilación
RUN pnpm turbo run build --filter=web

# --- NGINX: Servir la aplicación ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html

# Corregimos el error del COPY: apuntamos a la ruta más segura (build/client)
# El contenido se copia al directorio actual (WORKDIR)
COPY --from=builder /app/apps/web/build/client/ .

RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]