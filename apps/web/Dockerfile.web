# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos TODO
COPY . .

# 2. SCRIPT DE DESTRUCCIÓN DE MONOREPO: 
# Movemos las librerías a la raíz de la app web y borramos las menciones a @plane
RUN node -e "const fs=require('fs'); \
    const fixPkg = (path) => { \
    if (!fs.existsSync(path)) return; \
    const pkg = JSON.parse(fs.readFileSync(path, 'utf-8')); \
    const clean = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { \
    if (deps[d].includes('catalog:') || deps[d].includes('workspace:') || d.startsWith('@plane/')) { \
    delete deps[d]; \
    } \
    } \
    }; \
    clean(pkg.dependencies); clean(pkg.devDependencies); \
    fs.writeFileSync(path, JSON.stringify(pkg, null, 2)); \
    }; \
    fixPkg('package.json'); \
    fixPkg('apps/web/package.json');"

# 3. Instalación limpia de la WEB únicamente
WORKDIR /app/apps/web
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# 4. Intentamos compilar. 
# Si falla por falta de imports de @plane, sabremos que el código es inseparable.
RUN pnpm run build

# --- NGINX ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html
COPY --from=builder /app/apps/web/build/client/. ./
RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]