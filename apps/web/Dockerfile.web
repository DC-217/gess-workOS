# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos todo el monorepo (contexto ya validado)
COPY . .

# 2. SCRIPT DE LIMPIEZA TOTAL: Ahora también limpia 'overrides'
RUN node -e "const fs=require('fs'); \
    const fixPkg = (p) => { \
    if (!fs.existsSync(p)) return; \
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8')); \
    const clean = (obj) => { \
    if (!obj) return; \
    for (let key in obj) { \
    if (typeof obj[key] === 'string') { \
    if (obj[key].includes('catalog:')) obj[key] = '*'; \
    if (obj[key].includes('workspace:')) obj[key] = 'workspace:*'; \
    } \
    } \
    }; \
    clean(pkg.dependencies); \
    clean(pkg.devDependencies); \
    if (pkg.overrides) clean(pkg.overrides); \
    if (pkg.pnpm && pkg.pnpm.overrides) clean(pkg.pnpm.overrides); \
    pkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync(p, JSON.stringify(pkg, null, 2)); \
    }; \
    fixPkg('package.json'); \
    fixPkg('apps/web/package.json'); \
    fs.writeFileSync('pnpm-workspace.yaml', 'packages:\n  - \"apps/web\"\n  - \"packages/*\"');"

# 3. Instalación (Ahora sin errores de Catalogs en Overrides)
RUN pnpm install --no-frozen-lockfile

# 4. Build usando Turbo
RUN pnpm turbo run build --filter=web

# --- NGINX: Producción ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html
# Copiamos la salida de la build de React Router
COPY --from=builder /app/apps/web/build/client/. ./

RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]