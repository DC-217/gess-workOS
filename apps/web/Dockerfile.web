# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo completo
COPY . .

# 2. SCRIPT DE LIMPIEZA RECURSIVA
RUN node -e "const fs = require('fs'); const path = require('path'); \
    const walk = (dir) => { \
    fs.readdirSync(dir).forEach(file => { \
    let name = path.join(dir, file); \
    if (fs.statSync(name).isDirectory()) { \
    if (file !== 'node_modules' && file !== '.git') walk(name); \
    } else if (file === 'package.json') { \
    const pkg = JSON.parse(fs.readFileSync(name, 'utf-8')); \
    const fix = (obj) => { \
    if (!obj) return; \
    for (let k in obj) { \
    if (typeof obj[k] === 'string' && obj[k].includes('catalog:')) obj[k] = '*'; \
    if (typeof obj[k] === 'string' && obj[k].includes('workspace:')) obj[k] = 'workspace:*'; \
    } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); fix(pkg.peerDependencies); \
    if (pkg.overrides) fix(pkg.overrides); \
    if (pkg.pnpm && pkg.pnpm.overrides) fix(pkg.pnpm.overrides); \
    if (name === 'package.json') pkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync(name, JSON.stringify(pkg, null, 2)); \
    } \
    }); \
    }; \
    walk('.');"

# 3. Instalación
RUN pnpm install --no-frozen-lockfile

# Inyección de variables en build
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ARG NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ARG APP_BASE_URL
ENV APP_BASE_URL=$APP_BASE_URL
ARG NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL

# 4. Build de la web (Órbita)
RUN pnpm turbo run build --filter=web

# --- NODE: Servidor de Producción (EL CAMBIO REAL) ---
FROM base AS production
WORKDIR /app

# Copiamos todo el proyecto con el servidor incluido (No solo el cliente estático)
COPY --from=builder /app ./

# Variables de entorno de producción
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# Levantamos el servidor nativo de Node.js, adiós Nginx
CMD ["pnpm", "turbo", "run", "start", "--filter=web"]