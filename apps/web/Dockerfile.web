# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos todo el monorepo
COPY . .

# 2. SCRIPT DE COMPATIBILIDAD: Solo quitamos "catalog:" y "workspace:" 
# para que pnpm use las carpetas físicas que ya subiste.
RUN node -e "const fs=require('fs'); \
    const fix = (p) => { \
    if (!fs.existsSync(p)) return; \
    const pkg = JSON.parse(fs.readFileSync(p, 'utf-8')); \
    const clean = (deps) => { \
    if (!deps) return; \
    for (let d in deps) { \
    if (deps[d].includes('catalog:')) deps[d] = '*'; \
    if (deps[d].includes('workspace:')) deps[d] = 'workspace:*'; \
    } \
    }; \
    clean(pkg.dependencies); clean(pkg.devDependencies); \
    pkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync(p, JSON.stringify(pkg, null, 2)); \
    }; \
    fix('package.json'); \
    fix('apps/web/package.json'); \
    fs.writeFileSync('pnpm-workspace.yaml', 'packages:\n  - \"apps/web\"\n  - \"packages/*\"');"

# 3. Instalación: Ahora encontrará las carpetas de 'packages/'
RUN pnpm install --no-frozen-lockfile

# 4. Build: Usamos Turbo ahora que todo está en su lugar
RUN pnpm turbo run build --filter=web

# --- NGINX ---
FROM nginx:1.27-alpine AS production
# Copiamos la salida de la build (verifica si es 'dist' o 'build/client')
COPY --from=builder /app/apps/web/build/client /usr/share/nginx/html

RUN echo 'server { listen 3000; location / { root /usr/share/nginx/html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]