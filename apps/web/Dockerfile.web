# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.32.1 turbo@2.9.4

FROM base AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# 1. Copiamos el monorepo completo
COPY . .

# 2. SCRIPT DE LIMPIEZA RECURSIVA: Entra en las 17 carpetas y limpia todo
RUN node -e "const fs = require('fs'); const path = require('path'); \
    const walk = (dir) => { \
    fs.readdirSync(dir).forEach(file => { \
    let name = path.join(dir, file); \
    if (fs.statSync(name).isDirectory()) { \
    if (file !== 'node_modules' && file !== '.git') walk(name); \
    } else if (file === 'package.json') { \
    console.log('Cleaning: ' + name); \
    const pkg = JSON.parse(fs.readFileSync(name, 'utf-8')); \
    const fix = (obj) => { \
    if (!obj) return; \
    for (let k in obj) { \
    if (typeof obj[k] === 'string' && obj[k].includes('catalog:')) obj[k] = '*'; \
    if (typeof obj[k] === 'string' && obj[k].includes('workspace:')) obj[k] = 'workspace:*'; \
    } \
    }; \
    fix(pkg.dependencies); fix(pkg.devDependencies); fix(pkg.peerDependencies); \
    if (pkg.overrides) fix(pkg.overrides); \
    if (pkg.pnpm && pkg.pnpm.overrides) fix(pkg.pnpm.overrides); \
    if (name === 'package.json') pkg.packageManager = 'pnpm@10.32.1'; \
    fs.writeFileSync(name, JSON.stringify(pkg, null, 2)); \
    } \
    }); \
    }; \
    walk('.');"

# 3. Instalación (Ahora sí pasará por los 17 proyectos sin quejas)
RUN pnpm install --no-frozen-lockfile

# 4. Build: Usamos turbo para compilar la web
RUN pnpm turbo run build --filter=web

# --- NGINX: Producción ---
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html

# 1. Copiamos los archivos estáticos
COPY --from=builder /app/apps/web/build/client/. ./

# 2. Configuramos Nginx como Proxy Reverso
# Esto redirige cualquier llamada a /api directamente a tu servidor de Railway
RUN echo 'server { \
    listen 3000; \
    location /api/ { \
    proxy_pass https://gess-workos-api-production.up.railway.app/api/; \
    proxy_set_header Host gess-workos-api-production.up.railway.app; \
    proxy_set_header X-Real-IP $remote_addr; \
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; \
    proxy_set_header X-Forwarded-Proto $scheme; \
    proxy_ssl_server_name on; \
    } \
    location / { \
    root /usr/share/nginx/html; \
    try_files $uri $uri/ /index.html; \
    } \
    }' > /etc/nginx/conf.d/default.conf

# 3. Corregimos el puerto (Tenías EXPOSE 300, debe ser 3000)
EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]